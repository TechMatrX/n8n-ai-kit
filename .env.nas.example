# Synology DS218+ phase-1 example
# Copy to .env on the NAS working copy and fill real secrets before first run.

# NAS bind-mount root
NAS_ROOT=/volume1/docker/n8n-ai-kit

# External n8n URL on NAS
WEBHOOK_URL=https://your-nas-n8n.example.com
N8N_HOST=your-nas-n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://your-nas-n8n.example.com
N8N_HOST_PORT=5678
N8N_SECURE_COOKIE=true
N8N_API_KEY=

# n8n secrets
N8N_ENCRYPTION_KEY=replace-with-existing-stable-key
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-existing-stable-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=n8n

# Optional runtime values carried from local stack when needed
N8N_RELEASE_DATE=2025-03-06T00:00:00Z
NODE_FUNCTION_ALLOW_EXTERNAL=contentful-cli,@marp-team/marp-cli,youtube-transcript,@contentful/rich-text-from-markdown
OLLAMA_HOST=http://host.docker.internal:11434

# Contentful-related values only if your workflows need them
CONTENTFUL_MANAGEMENT_TOKEN=
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENV_ID=

# File access restrictions
N8N_RESTRICT_FILE_ACCESS_TO=/home/node/.n8n-files,/backup,/data/shared

# Keep auth/callback defaults explicit
N8N_SKIP_AUTH_ON_OAUTH_CALLBACK=false

# For plain HTTP LAN rehearsal only, temporarily set:
# N8N_SECURE_COOKIE=false
