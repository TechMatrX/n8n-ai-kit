POSTGRES_USER=root
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-a-long-random-string
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_RELEASE_DATE=2025-03-06T00:00:00Z
N8N_RESTRICT_FILE_ACCESS_TO=/home/node/.n8n-files,/backup,/data/shared
WEBHOOK_URL=http://localhost:5678

# Optional integrations used by Andy's current local stack
CONTENTFUL_MANAGEMENT_TOKEN=
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENV_ID=master
NODE_FUNCTION_ALLOW_EXTERNAL=youtube-transcript,@contentful/rich-text-from-markdown

# For Mac users running OLLAMA locally
# See https://github.com/n8n-io/self-hosted-ai-starter-kit?tab=readme-ov-file#for-mac--apple-silicon-users
# OLLAMA_HOST=host.docker.internal:11434

