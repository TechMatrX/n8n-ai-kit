POSTGRES_USER=root
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-a-long-random-string
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_RELEASE_DATE=2025-03-06T00:00:00Z
N8N_RESTRICT_FILE_ACCESS_TO=/home/node/.n8n-files,/backup,/data/shared
WEBHOOK_URL=http://localhost:5678
N8N_IMAGE=n8nio/n8n:2.23.4
N8N_RUNNERS_IMAGE=n8nio/runners:2.23.4
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
MINIO_IMAGE=quay.io/minio/minio:latest
RABBITMQ_IMAGE=rabbitmq:3.13-management-alpine
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_PULL_MODELS=qwen2.5:1.5b,nomic-embed-text

MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_BROWSER_REDIRECT_URL=
MINIO_SERVER_URL=

RABBITMQ_DEFAULT_USER=media_dispatch
RABBITMQ_DEFAULT_PASS=change-me
RABBITMQ_DEFAULT_VHOST=/
RABBITMQ_URL=amqp://media_dispatch:change-me@rabbitmq:5672/
RABBITMQ_EXCHANGE=media.jobs
RABBITMQ_QUEUE=media.jobs.ready
RABBITMQ_RETRY_EXCHANGE=media.jobs.retry
RABBITMQ_RETRY_QUEUE=media.jobs.retry.1m
RABBITMQ_DEAD_QUEUE=media.jobs.dead
RABBITMQ_HOST_BIND=127.0.0.1
RABBITMQ_MANAGEMENT_HOST_BIND=127.0.0.1
MEDIA_DISPATCH_MODE=http

# Optional integrations used by Andy's current local stack
CONTENTFUL_MANAGEMENT_TOKEN=
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENV_ID=master
NODE_FUNCTION_ALLOW_EXTERNAL=youtube-transcript,@contentful/rich-text-from-markdown

# For Mac users running OLLAMA locally
# See https://github.com/n8n-io/self-hosted-ai-starter-kit?tab=readme-ov-file#for-mac--apple-silicon-users
# OLLAMA_HOST=host.docker.internal:11434
